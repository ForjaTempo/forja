NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# FORJA contract addresses
NEXT_PUBLIC_FORJA_TOKEN_FACTORY=
NEXT_PUBLIC_FORJA_MULTISEND=
NEXT_PUBLIC_FORJA_LOCKER=
# ForjaLockerV2 — required for single/batch lock create & new-lock read/claim/revoke.
# Leave empty during rollout to gate the V2 UI (batch tab hidden, single lock uses V1).
NEXT_PUBLIC_FORJA_LOCKER_V2=
# ForjaClaimer — required for merkle claim pages (Phase 12A).
# Leave empty during rollout to hide the Claim nav and block /claim/create.
NEXT_PUBLIC_FORJA_CLAIMER=

# Database (PostgreSQL)
DATABASE_URL=

# Indexer
INDEXER_API_KEY=
INDEXER_RPC_URL=

# Phase 12A Claim Pages (optional)
# First-week whole-token deposit cap per campaign (default 1000). Set to a high value to disable.
CLAIM_CAP_USD=
# Unix seconds of ForjaClaimer mainnet deploy. 0 disables the canary cap window entirely.
CLAIMER_DEPLOY_TIMESTAMP=

# Phase 14 Launchpad (optional — leave empty to disable launchpad UI)
NEXT_PUBLIC_FORJA_LAUNCHPAD=
NEXT_PUBLIC_LAUNCHPAD_ENABLED=false

# Analytics (OpenPanel — optional, analytics disabled if not set)
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
NEXT_PUBLIC_OPENPANEL_API_URL=
