# Database
DATABASE_URL=postgresql://user:password@localhost:5432/forja

# Session cookie signing (32 random bytes, base64). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# WalletConnect Cloud project ID — https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Tempo Blockchain
NEXT_PUBLIC_TEMPO_RPC_URL=https://rpc.tempo.xyz
NEXT_PUBLIC_CHAIN_ID=4217

# Contract Addresses (Tempo system contracts)
NEXT_PUBLIC_TIP20_FACTORY=0x20Fc000000000000000000000000000000000000
NEXT_PUBLIC_PATHUSD=0x20C0000000000000000000000000000000000000

# Forja Contract Addresses (set after deployment)
NEXT_PUBLIC_FORJA_TOKEN_FACTORY=
NEXT_PUBLIC_FORJA_MULTISEND=
NEXT_PUBLIC_FORJA_LOCKER=

# Treasury
NEXT_PUBLIC_TREASURY=

# Indexer
INDEXER_API_KEY=dev-secret-key
INDEXER_RPC_URL=https://rpc.moderato.tempo.xyz

# Deployer (contracts only — never expose to frontend)
DEPLOYER_PRIVATE_KEY=
